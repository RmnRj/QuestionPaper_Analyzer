        { "topic": "1.6 Some basic relationships like Neighbors, Connectivity, Distance Measures between pixels" },
        { "topic": "1.7 Elements of Visual Perception" }
      ]
    },
    {
      "unit": 2,
      "title": "Image Enhancement in Spatial Domain",
      "hours": 7,
      "topics": [
        { "topic": "2.1 Some basic Gray Level Transformations" },
        { "topic": "2.1.1 Point operations" },
        { "topic": "2.1.2 Contrast stretching" },
